PAYPAL_DEBUG_TOKEN=SET_A_LONG_RANDOM_DEBUG_TOKEN
PAYMENTS_STORE_FILE=.payments-store.db
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME